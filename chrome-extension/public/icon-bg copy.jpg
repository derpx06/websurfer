<svg width="128" height="128" viewBox="0 0 128 128" fill="none" xmlns="http://www.w3.org/2000/svg">
  <defs>

    <!-- Deep navy base -->
    <radialGradient id="bg" cx="38%" cy="28%" r="82%">
      <stop offset="0%"   stop-color="#0d1f42"/>
      <stop offset="58%"  stop-color="#070d1c"/>
      <stop offset="100%" stop-color="#030710"/>
    </radialGradient>

    <!-- Cyan ambient bloom — top-left -->
    <radialGradient id="gc" cx="18%" cy="18%" r="58%">
      <stop offset="0%"   stop-color="#38bdf8" stop-opacity=".18"/>
      <stop offset="100%" stop-color="#38bdf8" stop-opacity="0"/>
    </radialGradient>

    <!-- Violet ambient bloom — bottom-right -->
    <radialGradient id="gv" cx="84%" cy="86%" r="50%">
      <stop offset="0%"   stop-color="#818cf8" stop-opacity=".14"/>
      <stop offset="100%" stop-color="#818cf8" stop-opacity="0"/>
    </radialGradient>

    <!-- Secondary cyan bloom — center-right -->
    <radialGradient id="gc2" cx="80%" cy="40%" r="40%">
      <stop offset="0%"   stop-color="#38bdf8" stop-opacity=".07"/>
      <stop offset="100%" stop-color="#38bdf8" stop-opacity="0"/>
    </radialGradient>

    <!-- Wave body fills — deep ocean blues -->
    <linearGradient id="w1" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#1a5c96"/>
      <stop offset="100%" stop-color="#0b2e50"/>
    </linearGradient>
    <linearGradient id="w2" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#124a7a"/>
      <stop offset="100%" stop-color="#082038"/>
    </linearGradient>
    <linearGradient id="w3" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#0b3860"/>
      <stop offset="100%" stop-color="#04121e"/>
    </linearGradient>

    <!-- Wave crest highlights — cyan glow fading at edges -->
    <linearGradient id="c1" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%"   stop-color="#38bdf8" stop-opacity="0"/>
      <stop offset="28%"  stop-color="#38bdf8" stop-opacity=".80"/>
      <stop offset="58%"  stop-color="#7ee8ff" stop-opacity=".62"/>
      <stop offset="85%"  stop-color="#38bdf8" stop-opacity=".30"/>
      <stop offset="100%" stop-color="#38bdf8" stop-opacity="0"/>
    </linearGradient>
    <linearGradient id="c2" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%"   stop-color="#38bdf8" stop-opacity="0"/>
      <stop offset="22%"  stop-color="#5bc8f8" stop-opacity=".60"/>
      <stop offset="55%"  stop-color="#7ee8ff" stop-opacity=".42"/>
      <stop offset="82%"  stop-color="#38bdf8" stop-opacity=".18"/>
      <stop offset="100%" stop-color="#38bdf8" stop-opacity="0"/>
    </linearGradient>
    <linearGradient id="c3" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%"   stop-color="#5b7cf8" stop-opacity="0"/>
      <stop offset="25%"  stop-color="#6488fa" stop-opacity=".45"/>
      <stop offset="55%"  stop-color="#818cf8" stop-opacity=".32"/>
      <stop offset="80%"  stop-color="#818cf8" stop-opacity=".12"/>
      <stop offset="100%" stop-color="#818cf8" stop-opacity="0"/>
    </linearGradient>

    <!-- Foam/spray dots gradient -->
    <radialGradient id="foam" cx="50%" cy="50%" r="50%">
      <stop offset="0%"   stop-color="#7ee8ff" stop-opacity=".55"/>
      <stop offset="100%" stop-color="#38bdf8" stop-opacity="0"/>
    </radialGradient>

    <clipPath id="sq"><rect width="128" height="128" rx="24"/></clipPath>

  </defs>

  <!-- ── Outer rounded square background ── -->
  <rect width="128" height="128" rx="24" fill="url(#bg)"/>

  <!-- ── Ambient light blooms ── -->
  <rect width="128" height="128" rx="24" fill="url(#gc)"/>
  <rect width="128" height="128" rx="24" fill="url(#gv)"/>
  <rect width="128" height="128" rx="24" fill="url(#gc2)"/>

  <g clip-path="url(#sq)">

    <!-- ══════════════════════════════════════
         THREE ROLLING OCEAN WAVES
         Layer order: w3 (back) → w2 → w1 (front)
         Each wave sweeps from left to right
         with a rolling S-curve, filling the
         lower portion of the icon.
         ══════════════════════════════════════ -->

    <!-- Wave 3 — deepest, furthest back -->
    <path d="M 0 94
             Q 16 86 32 90
             Q 48 94 64 86
             Q 80 78 96 82
             Q 112 86 128 78
             L 128 128 L 0 128 Z"
      fill="url(#w3)"/>

    <!-- Wave 2 — mid layer -->
    <path d="M 0 86
             Q 18 77 36 82
             Q 54 87 70 78
             Q 86 69 104 74
             Q 116 78 128 70
             L 128 128 L 0 128 Z"
      fill="url(#w2)"/>

    <!-- Wave 1 — front / closest, lightest -->
    <path d="M 0 78
             Q 20 68 38 74
             Q 56 80 72 70
             Q 88 60 106 66
             Q 118 70 128 62
             L 128 128 L 0 128 Z"
      fill="url(#w1)"/>

    <!-- Crest highlights — bright edge of each wave top -->
    <path d="M 0 78 Q 20 68 38 74 Q 56 80 72 70 Q 88 60 106 66 Q 118 70 128 62"
      stroke="url(#c1)" stroke-width="2.2" fill="none" stroke-linecap="round"/>

    <path d="M 0 86 Q 18 77 36 82 Q 54 87 70 78 Q 86 69 104 74 Q 116 78 128 70"
      stroke="url(#c2)" stroke-width="1.7" fill="none" stroke-linecap="round"/>

    <path d="M 0 94 Q 16 86 32 90 Q 48 94 64 86 Q 80 78 96 82 Q 112 86 128 78"
      stroke="url(#c3)" stroke-width="1.3" fill="none" stroke-linecap="round"/>

    <!-- Foam spray dots on front wave crest -->
    <circle cx="38"  cy="74" r="1.8" fill="url(#foam)"/>
    <circle cx="56"  cy="79" r="1.4" fill="url(#foam)"/>
    <circle cx="72"  cy="70" r="2"   fill="url(#foam)"/>
    <circle cx="88"  cy="61" r="1.5" fill="url(#foam)"/>
    <circle cx="106" cy="66" r="1.8" fill="url(#foam)"/>
    <circle cx="20"  cy="70" r="1.2" fill="url(#foam)"/>
    <!-- Smaller secondary foam dots -->
    <circle cx="30"  cy="77" r="1"   fill="#7ee8ff" fill-opacity=".30"/>
    <circle cx="64"  cy="74" r="1"   fill="#7ee8ff" fill-opacity=".25"/>
    <circle cx="96"  cy="69" r="1"   fill="#7ee8ff" fill-opacity=".28"/>

  </g>

  <!-- Glass rim highlight -->
  <rect x=".8" y=".8" width="126.4" height="126.4" rx="23.4"
    fill="none" stroke="rgba(255,255,255,.07)" stroke-width="1.4"/>

</svg>
